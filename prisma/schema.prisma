generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum OrderEventType {
  ORDER_CONFIRMED
  PAYMENT_FAILED
  REFUNDED
  STATUS_UPDATED
  STOCK_RESTORED
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  address   String?
  emailVerifiedAt DateTime?
  deletedAt DateTime?
  role      Role     @default(CLIENT)
  orders    Order[]
  verificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  createdAt DateTime @default(now())

  @@index([email])
}

model Category {
  id       String     @id @default(cuid())
  name     String
  slug     String     @unique
  parentId String?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id])
  children Category[] @relation("SubCategories")
  products Product[]

  @@index([slug])
  @@index([parentId])
}

model Brand {
  id      String    @id @default(cuid())
  name    String
  slug    String    @unique
  logo    String?
  products Product[]

  @@index([slug])
}

model Product {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  price       Int
  salePrice   Int?
  images      Json            @default("[]")
  stock       Int             @default(0)
  status      ProductStatus   @default(DRAFT)
  isNew       Boolean         @default(false)
  // Couleur dominante (optionnelle) — id issu de lib/colors.ts (ex.
  // "rose", "dore"…). Sert uniquement à alimenter la catégorie transverse
  // "Acheter par couleur" (/categorie/couleurs), pas de FK : reste un
  // simple texte libre pour éviter une table de référence supplémentaire.
  color       String?
  brandId     String
  brand       Brand           @relation(fields: [brandId], references: [id])
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  variants    ProductVariant[]
  stone       Stone?
  orderItems  OrderItem[]
  wishlistItems WishlistItem[]
  reviews     Review[]
  tags        Json            @default("[]")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([slug])
  @@index([brandId])
  @@index([categoryId])
  @@index([status])
  @@index([color])
  @@index([status, categoryId])
  @@index([status, createdAt])
  @@index([name])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String
  value     String
  stock     Int      @default(0)
  price     Int?

  @@index([productId])
}

model Stone {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  name      String
  color     String
  virtues   Json     @default("[]")

  @@unique([productId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  events          OrderEvent[]
  total           Int
  status          OrderStatus @default(PENDING)
  stripePaymentId String?     @unique
  stripeIntentId  String?     @unique
  // Suivi colis, rempli manuellement par l'admin au moment de l'expédition
  // (voir lib/carriers.ts pour la liste des transporteurs + génération du
  // lien de suivi). Texte libre, pas de FK : pas besoin d'une table dédiée
  // pour un simple identifiant transporteur.
  carrier         String?
  trackingNumber  String?
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

model OrderEvent {
  id            String         @id @default(cuid())
  orderId       String
  order         Order          @relation(fields: [orderId], references: [id])
  type          OrderEventType
  message       String?
  data          Json           @default("{}")
  stripeEventId String?        @unique
  createdAt     DateTime       @default(now())

  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?
  quantity  Int
  price     Int

  @@index([orderId])
}

model EmailVerificationToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Review {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  rating    Int
  comment   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([userId])
  @@index([approved])
}
